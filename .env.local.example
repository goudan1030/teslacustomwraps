# Local-only secrets and overrides.
# Copy this file to `.env.local` and fill values on your machine.

VITE_APP_ENV=local
VITE_APP_BASE_URL=http://localhost:3000

# Server-side APIYi key for Vite proxy / Netlify Functions.
# Do not use a `VITE_` prefix here, otherwise the key may be exposed to the browser bundle.
APIYI_API_KEY=

# Optional server-side overrides
APIYI_BASE_URL=https://api.apiyi.com
APIYI_MODEL=gpt-image-2-all
APIYI_NANO_BANANA_MODEL=gemini-3.1-flash-image-preview

# Optional client-side services
# VITE_GA_MEASUREMENT_ID=
# VITE_GOOGLE_CLIENT_ID=
# VITE_HUGGINGFACE_API_KEY=
# VITE_REPLICATE_API_TOKEN=
# VITE_OPENAI_API_KEY=
# VITE_GEMINI_API_KEY=
